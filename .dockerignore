# Build context hygiene: ship only what `npm run build` needs.
# Never copy host state or secrets into an image layer.

# deps & build output (rebuilt inside the image)
node_modules
dist
server-dist

# local state & secrets (gitignored — keep them out of layers too)
data
backups
relay.json
relay.json.tmp
relay-backup-*.json
secrets.json
*.secrets.json
secrets.json.tmp
.env
.env.*
*.pem
*.key
service-account*.json
gcp-*.json
vertex-*.json

# repo metadata & docs (not needed to build)
.git
.github
.gitignore
.dockerignore
Dockerfile
*.md
.vscode
.idea
