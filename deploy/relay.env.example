# Relay server config — copy this to /opt/relay/.env, fill it in, then:
#   chmod 600 /opt/relay/.env
# (.env is gitignored and must never be committed — it can hold secrets.)

# Port the Node server listens on. Caddy reverse-proxies to it. Default: 8787.
API_PORT=8787

# Where server-side backups are written. The service user must be able to
# write here. (This dir holds plaintext API keys — keep it private.)
RELAY_BACKUP_DIR=/opt/relay/backups

# --- Auth gate (STRONGLY recommended for any public host) -------------------
# When BOTH are set, the whole site (app + API) requires these HTTP Basic
# credentials. Use a long, random password with no spaces. Leave unset only
# for a private LAN / local run.
RELAY_AUTH_USER=you
RELAY_AUTH_PASS=replace-with-a-long-random-string

# --- Optional provider fallbacks --------------------------------------------
# You can instead enter keys in the app's Settings (they live in the browser).
# These are only a server-side fallback for the chat proxy + model listing.
# OPENROUTER_KEY=
# OPENAI_KEY=

# --- Vertex AI (only if you use it) -----------------------------------------
# Prefer the FILE form on a server (avoids quoting a big JSON in this file):
# GOOGLE_VERTEX_CREDENTIALS_FILE=/opt/relay/vertex-sa.json
# Or inline the service-account JSON on one line:
# GOOGLE_VERTEX_CREDENTIALS={"type":"service_account",...}
