# Relay reverse proxy — install at /etc/caddy/Caddyfile, then `sudo systemctl reload caddy`.
#
# Replace relay.example.com with YOUR domain. Its DNS A record must point at the
# VPS's public IP first — then Caddy fetches + auto-renews a Let's Encrypt cert
# and redirects http -> https on its own. No domain? Get a free one at duckdns.org.

relay.example.com {
	encode zstd gzip
	# Relay's Node server (the systemd unit) listens here.
	reverse_proxy 127.0.0.1:8787
}
