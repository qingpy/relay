# Relay proxy server config — copy to `.env` and fill in as needed.
# All keys are OPTIONAL. Provider API keys can also be entered in the app UI
# (stored in IndexedDB) instead of here.

# Port the Hono proxy listens on (Vite dev proxy forwards /api here).
API_PORT=8787

# --- OpenRouter / OpenAI-compatible (optional server-side fallback key) ---
OPENROUTER_KEY=
# Override base URL for OpenAI-compatible providers (default OpenRouter).
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# --- Google Gemini AI Studio (optional server-side fallback key) ---
GEMINI_KEY=

# --- Google Vertex AI (service account stays server-side ONLY) ---
# Either a path to the service-account JSON file...
GOOGLE_APPLICATION_CREDENTIALS=
# ...or the JSON inline (one of the two).
# GOOGLE_APPLICATION_CREDENTIALS_JSON=
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1

# --- WebDAV sync (optional) ---
WEBDAV_URL=
WEBDAV_USER=
WEBDAV_PASS=
WEBDAV_PATH=/relay/relay-backup.json
